styles {
    element "Person" {
        shape Person
        background #08427b
        color #ffffff
    }
    element "Software System" {
        background #1168bd
        color #ffffff
    }
    element "Container" {
        background #438dd5
        color #ffffff
    }
    element "Component" {
        background #85bbf0
        color #000000
        shape RoundedBox
    }
    element "Database" {
        shape Cylinder
        background #228b22
        color #ffffff
    }
    element "MessageBus" {
        shape Pipe
        background #e07a5f
        color #ffffff
    }
    element "External" {
        background #999999
        color #ffffff
    }
    element "port.in" {
        background #b3d4fc
    }
    element "port.out" {
        background #c8e6c9
    }
}
